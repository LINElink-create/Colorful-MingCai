APP_NAME=Mingcai Backend
APP_ENV=production
APP_HOST=0.0.0.0
APP_PORT=8000
APP_VERSION=0.1.0
LOG_LEVEL=info
DEPLOY_ENV=production
SERVER_PUBLIC_BASE_URL=https://api.example.com
TRUSTED_PROXIES=127.0.0.1
MYSQL_HOST=10.0.0.20
MYSQL_PORT=3306
MYSQL_USER=mingcai_app
MYSQL_PASSWORD=replace-with-real-password
MYSQL_DATABASE=mingcai
DATABASE_ECHO=false
CORS_ORIGINS=chrome-extension://your-extension-id
DEFAULT_TRANSLATION_PROVIDER=youdao
PLATFORM_TRANSLATION_ENABLED=true
PLATFORM_YOUDAO_APP_KEY=replace-with-real-app-key
PLATFORM_YOUDAO_APP_SECRET=replace-with-real-app-secret
PLATFORM_REQUESTS_PER_MINUTE=30
PLATFORM_DAILY_LIMIT=5000
GUNICORN_WORKERS=2
GUNICORN_TIMEOUT=120
GUNICORN_GRACEFUL_TIMEOUT=30
GUNICORN_KEEPALIVE=5
IMAGE_TAG=main
GITHUB_REPOSITORY_OWNER=your-github-user-or-org